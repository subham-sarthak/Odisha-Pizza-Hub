# ==========================================
# ODISHA PIZZA HUB - BACKEND CONFIGURATION
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# For Local Development: mongodb://127.0.0.1:27017/odisha_pizza
# For Production: mongodb+srv://username:password@cluster.mongodb.net/odisha-pizza
MONGO_URI=mongodb://127.0.0.1:27017/odisha_pizza

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Generate a strong secret key for production:
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super-secret-refresh-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# ==========================================
# REDIS CACHE
# ==========================================
# For Local Development: redis://127.0.0.1:6379
# For Production: redis://user:password@host:port
# Or use Redis Cloud: redis://:password@host:port
REDIS_URL=redis://127.0.0.1:6379

# ==========================================
# FRONTEND URL (CORS)
# ==========================================
# Keep the hostname style consistent with the frontend.
# Example: use localhost on both sides, not localhost on one side and 127.0.0.1 on the other.
FRONTEND_URL=http://localhost:5173

# ==========================================
# RAZORPAY PAYMENT GATEWAY
# ==========================================
# Get keys from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_test_secret
RAZORPAY_WEBHOOK_SECRET=webhook_secret

# ==========================================
# NOTIFICATION SERVICES
# ==========================================
# Set to "mock" for development (logs to console)
# Set to "live" or provider name for production
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
EMAIL_PROVIDER=mock
MAIL_FROM=Odisha Pizza Hub <no-reply@odishapizza.com>

# Optional: SMTP Email Configuration (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: SMS Configuration (Twilio, AWS SNS, etc.)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Optional: WhatsApp Configuration
# WHATSAPP_API_URL=https://api.whatsapp.com
# WHATSAPP_API_TOKEN=your_token
