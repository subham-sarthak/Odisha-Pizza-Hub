# ==========================================
# ODISHA PIZZA HUB - FRONTEND CONFIGURATION
# ==========================================

# Backend API Configuration
# For Local Development: http://localhost:5000/api
# Keep hostname style aligned with BACKEND FRONTEND_URL for cookies and CSRF.
# Example: if backend FRONTEND_URL uses localhost, use localhost here too.
# For Production: https://api.odishapizza.com/api
VITE_API_URL=http://localhost:5000/api

# Socket.io Server URL
# For Local Development: http://localhost:5000
# For Production: https://api.odishapizza.com
VITE_SOCKET_URL=http://localhost:5000

# Razorpay Payment Gateway
# Get from: https://dashboard.razorpay.com/
# Use test key for development, production key for live environment
VITE_RAZORPAY_KEY_ID=rzp_test_key

# Optional: Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: Environment Name
# VITE_APP_ENV=development
